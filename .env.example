# Jellyfin Configuration
# JELLYFIN_URL=http://localhost:8096
# JELLYFIN_API_KEY=your-jellyfin-api-key
# JELLYFIN_USERNAME=your-jellyfin-username

# Plex Configuration (optional)
# PLEX_URL=http://localhost:32400
# PLEX_TOKEN=your-plex-token

# StreamyStats Configuration (optional — enables watchlist shuffle)
# STREAMYSTATS_URL=http://localhost:3000
# STREAMYSTATS_TOKEN=your-jellyfin-user-access-token

# Optional request timeout in seconds for upstream Jellyfin/Plex/StreamyStats calls
# REQUEST_TIMEOUT=15
